---
// 气泡上升效果组件
---

<script is:inline define:vars={{ themeColor: '#ff9671' }}>
(function() {
  // 防止重复初始化
  if (window.vhPaopaoInitialized) return;
  window.vhPaopaoInitialized = true;

  const canvas = document.createElement('canvas');
  canvas.className = 'vh-paopao';
  canvas.setAttribute('style', 'position: fixed; left: 0; top: 0; width: 100%; height: 100%; pointer-events: none; z-index: 1;');
  
  // 等待 DOM 加载完成
  function init() {
    // 查找合适的位置插入 canvas
    const banner = document.querySelector('.banner') || document.querySelector('.vh-header') || document.body;
    if (banner && !document.querySelector('.vh-paopao')) {
      banner.appendChild(canvas);
    }
    
    initBubble();
  }

  function initBubble() {
    const ctx = canvas.getContext('2d');
    let animationId;
    let bubbles = [];
    const bubbleCount = 30;
    
    function resize() {
      canvas.width = window.innerWidth;
      canvas.height = window.innerHeight;
    }
    
    resize();
    window.addEventListener('resize', resize);

    class Bubble {
      constructor() {
        this.reset();
      }
      
      reset() {
        this.x = Math.random() * canvas.width;
        this.y = canvas.height + Math.random() * 100;
        this.radius = 3 + Math.random() * 8;
        this.speed = 0.5 + Math.random() * 1.5;
        this.wobble = Math.random() * Math.PI * 2;
        this.wobbleSpeed = 0.02 + Math.random() * 0.03;
        this.opacity = 0.1 + Math.random() * 0.4;
      }
      
      update() {
        this.y -= this.speed;
        this.wobble += this.wobbleSpeed;
        this.x += Math.sin(this.wobble) * 0.3;
        
        if (this.y + this.radius < 0) {
          this.reset();
        }
      }
      
      draw() {
        ctx.beginPath();
        ctx.arc(this.x, this.y, this.radius, 0, Math.PI * 2);
        ctx.fillStyle = `rgba(255, ${150 + Math.random() * 50}, ${100 + Math.random() * 50}, ${this.opacity})`;
        ctx.fill();
        
        // 高光
        ctx.beginPath();
        ctx.arc(this.x - this.radius * 0.3, this.y - this.radius * 0.3, this.radius * 0.3, 0, Math.PI * 2);
        ctx.fillStyle = `rgba(255, 255, 255, ${this.opacity * 0.5})`;
        ctx.fill();
      }
    }
    
    for (let i = 0; i < bubbleCount; i++) {
      const bubble = new Bubble();
      bubble.y = Math.random() * canvas.height; // 初始分布在整个屏幕
      bubbles.push(bubble);
    }
    
    function animate() {
      ctx.clearRect(0, 0, canvas.width, canvas.height);
      
      bubbles.forEach(bubble => {
        bubble.update();
        bubble.draw();
      });
      
      animationId = requestAnimationFrame(animate);
    }
    
    animate();
  }

  // 等待 DOM 加载
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
})();
</script>
